NODE_ENV=development
PORT=3000

# PostgreSQL veya Supabase connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/emba_professional

# Production icin uzun ve rastgele bir deger kullanin.
SESSION_SECRET=local-development-secret-change-me

# Ilk kurulumda admin hesabi bu sifreyle olusturulur.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Degistir123!

# Render/Supabase gibi uzak PostgreSQL servislerinde true gerekebilir.
DATABASE_SSL=false

# Otomatik JSON yedegi kac saatte bir calissin?
AUTO_BACKUP_HOURS=24
