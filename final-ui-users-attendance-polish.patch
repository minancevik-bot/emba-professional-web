+  font-size: 16px;
+  line-height: 1;
+}
+
+.time-chip span {
+  width: auto;
+  min-width: 0;
+  height: auto;
+  padding: 3px 8px;
+  background: #f3f4f6;
+  color: var(--muted);
+  font-weight: 800;
+}
+
+.time-chip.active span {
+  background: rgba(255, 255, 255, 0.18);
+  color: #fff;
+}
+
+.time-chip.empty {
+  color: #6b7280;
+  background: #f9fafb;
+}
+
+.time-chip.empty span {
+  background: #e5e7eb;
+}
+
+@media (max-width: 980px) {
+  .dashboard-hero {
+    grid-template-columns: 1fr;
+  }
+
+  .user-filter-panel {
+    grid-template-columns: 1fr;
+  }
+
+  .time-picker {
+    width: 100%;
+  }
+
+  .time-chip-grid {
+    grid-template-columns: repeat(2, minmax(120px, 1fr));
+  }
+}
+
+@media (max-width: 520px) {
+  .time-chip-grid {
+    grid-template-columns: 1fr;
+  }
+}
